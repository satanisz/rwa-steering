flowchart LR
    REQ["Request<br/>anonymized RWA input + calculator output"]

    subgraph ENTRY["Pre-Graph Entry Layer"]
        V1["Request Validation<br/>schema + required fields"]
        V2["PII Guard<br/>reject PII-like fields"]
        V3["Identifier Normalization<br/>allowed anonymized IDs only"]
        V4["AgentState Builder<br/>Pydantic v2"]
        VREJ["Rejected Request<br/>does not enter graph"]
    end

    subgraph STATE["AgentState"]
        S1["rwa_input_data"]
        S2["rwa_output_results"]
        S3["messages"]
        S4["validation_flags"]
        S5["agent_findings"]
        S6["recommended_actions"]
        S7["commentary_views"]
        S8["guardrail_results"]
        S9["loop_count / loop_limit = 2"]
        S10["consensus_reached"]
        S11["final_commentary"]
    end

    subgraph GRAPH["Compact LangGraph Runtime"]
        A["AnalysisPhase node<br/>fan-out / fan-in"]
        SUP["SupervisorAgent node<br/>merge / consensus / loop limit / synthesis"]
        ROUTE{"Route"}
        FOG["Final Output Guard"]
        END["FinalStructuredResponse"]
    end

    subgraph WORKERS["Parallel ReAct workers inside AnalysisPhase"]
        DA["DataAnalystAgent<br/>inspect -> select tools -> execute -> observe -> structured finding"]
        RE["RiskExpertAgent<br/>inspect -> select tools -> execute -> observe -> structured finding"]
    end

    subgraph DATA_TOOLS["DataTools - deterministic Python"]
        DT1["Duplicate asset ID detection"]
        DT2["Missing output detection"]
        DT3["Missing risk parameter detection<br/>rating / PD / LGD / EAD / risk weight"]
        DT4["Non-positive exposure checks"]
        DT5["Exposure concentration analysis"]
        DT6["Portfolio / sector / asset-class anomaly detection"]
    end

    subgraph RISK_TOOLS["RiskTools - deterministic Python"]
        RT1["Deterministic RWA validation"]
        RT2["RWA movement-driver analysis"]
        RT3["Portfolio / sector / risk-class / rating-migration impacts"]
        RT4["Capital and management-buffer concern detection"]
        RT5["Basel / internal-policy context where available"]
    end

    subgraph GUARD["LLM Guard - coarse safe boundaries"]
        G1["Before each LLM-facing call<br/>prompt + summarized context scan"]
        G2["After each LLM response<br/>generated output scan"]
        G3["Before final response<br/>generated commentary scan"]
        G4["Blocked event<br/>unsafe output is not written to AgentState"]
    end

    subgraph PROMPTS["Prompt Registry"]
        PR1["Langfuse Prompt Registry<br/>when enabled"]
        PR2["Local fallback registry<br/>when disabled"]
        PR3["TTL cache"]
        PR4["rwa-data-analyst-agent-system"]
        PR5["rwa-risk-expert-agent-system"]
        PR6["rwa-supervisor-agent-system"]
    end

    subgraph OBS["Langfuse Observability - optional"]
        O1["graph execution ID + thread ID"]
        O2["node transitions + selected agents"]
        O3["LLM calls + token usage + latency"]
        O4["deterministic tool calls"]
        O5["prompt versions"]
        O6["LLM Guard scan results + blocked events"]
        O7["evaluation scores<br/>Faithfulness / Groundedness / Anomaly_Detection / Guardrail_Block_Count / PII_Detected / Prompt_Injection_Risk"]
    end

    subgraph MEMORY["MemorySaver / Checkpointer"]
        M1["Persist AgentState"]
        M2["thread_id = request_id or generated run_id"]
        M3["loop recovery"]
        M4["human-in-the-loop readiness"]
    end

    REQ --> V1
    V1 -->|invalid| VREJ
    V1 -->|valid| V2
    V2 -->|PII-like fields detected| VREJ
    V2 -->|safe| V3 --> V4 --> STATE

    STATE --> A
    A --> DA
    A --> RE
    DA --> DATA_TOOLS --> DA
    RE --> RISK_TOOLS --> RE
    DA --> S5
    RE --> S5
    S5 --> SUP
    SUP --> ROUTE
    ROUTE -->|required findings missing| A
    ROUTE -->|critical flags and loop_count < 2| A
    ROUTE -->|completed| FOG
    ROUTE -->|loop limit reached| FOG
    ROUTE -->|blocked| G4
    FOG -->|safe| END
    FOG -->|blocked| G4 --> END

    G1 -.-> DA
    G2 -.-> DA
    G1 -.-> RE
    G2 -.-> RE
    G1 -.-> SUP
    G2 -.-> SUP
    G3 -.-> FOG

    PROMPTS -.-> DA
    PROMPTS -.-> RE
    PROMPTS -.-> SUP
    PR1 --> PR3
    PR2 --> PR3
    PR3 --> PR4
    PR3 --> PR5
    PR3 --> PR6

    STATE -.-> MEMORY
    A -.-> M3
    SUP -.-> M3
    M1 --> M2
    M1 --> M4

    REQ -.-> OBS
    GRAPH -.-> OBS
    WORKERS -.-> OBS
    DATA_TOOLS -.-> OBS
    RISK_TOOLS -.-> OBS
    GUARD -.-> OBS
    PROMPTS -.-> OBS
    MEMORY -.-> OBS
